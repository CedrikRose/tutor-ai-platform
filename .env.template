# AWS Bedrock credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# LlamaParse API key (get from https://cloud.llamaindex.ai/)
LLAMA_CLOUD_API_KEY=your_llama_parse_api_key_here

# Database
DATABASE_URL=postgresql://ai_tutor:dev_password@localhost:5432/ai_tutor_dev

# Models
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL_PRIMARY=moonshotai.kimi-k2.5
BEDROCK_LLM_MODEL_SECONDARY=minimax.minimax-m2.5

# Rate limiting and batch processing
MAX_CONCURRENT_PARSES=3
PARSE_BATCH_SIZE=5
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY=2.0
RETRY_MAX_DELAY=300.0

# Embedding settings
EMBEDDING_BATCH_SIZE=25
MAX_CONCURRENT_EMBEDDINGS=10

# JWT Authentication (Professor Dashboard)
# IMPORTANT: Generate a secure 256-bit random key for production!
# Example: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_SECRETS_MANAGER_256BIT_RANDOM_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Context Window
CONTEXT_WINDOW_SIZE=32000
CONTEXT_WARNING_THRESHOLD=0.8

# Scheduler
EXPORT_HOUR=4
EXPORT_TIMEZONE=Europe/Berlin

# File Upload
FILE_STORAGE_TYPE=local  # 'local' for dev, 's3' for production
FILE_STORAGE_PATH=./uploads
AWS_S3_BUCKET=ai-tutor-uploads
MAX_FILE_SIZE_MB=100
