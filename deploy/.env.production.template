# AI-Tutor Production Environment Configuration
# Copy this to /opt/ai-tutor/.env and fill in your values

# Database
DATABASE_URL=postgresql://ai_tutor_prod:YOUR_DB_PASSWORD_HERE@localhost/ai_tutor_prod

# AWS Bedrock Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# LlamaParse (for document parsing)
LLAMA_CLOUD_API_KEY=YOUR_LLAMAPARSE_KEY

# Authentication
JWT_SECRET_KEY=YOUR_JWT_SECRET_HERE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
PROFESSOR_REGISTRATION_CODE=YOUR_SECURE_REGISTRATION_CODE

# CORS Configuration
# Add your EC2 IP or domain
CORS_ORIGINS=http://localhost:3000,http://YOUR_EC2_IP,http://YOUR_EC2_IP:8080

# Email Configuration (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# File Storage
UPLOAD_DIR=/opt/ai-tutor/uploads
MAX_UPLOAD_SIZE_MB=50

# Application Settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Rate Limiting
MAX_CONCURRENT_PARSES=3
MAX_CONCURRENT_EMBEDDINGS=10
PARSE_BATCH_SIZE=5

# Retry Configuration
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY=2.0
RETRY_MAX_DELAY=300.0
